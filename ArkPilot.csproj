<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<OutputType>WinExe</OutputType>
		<TargetFramework>net10.0-windows</TargetFramework>
		<UseWPF>true</UseWPF>

		<Nullable>enable</Nullable>
		<ImplicitUsings>enable</ImplicitUsings>

		<AssemblyName>ArkPilot</AssemblyName>
		<RootNamespace>ArkPilot</RootNamespace>

		<Product>ArkPilot</Product>
		<Title>ArkPilot</Title>
		<Description>Modern Windows manager for ARK: Survival Ascended servers.</Description>
		<Authors>Damien Dechaume</Authors>
		<Version>12.6.0</Version>

		<ApplicationIcon>Assets\Images\ArkPilot.ico</ApplicationIcon>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="CoreRCON" Version="5.4.2" />
		<PackageReference Include="FluentFTP" Version="54.2.0" />
		<PackageReference Include="LiveChartsCore.SkiaSharpView.WPF"
						  Version="2.0.5" />
	</ItemGroup>

	<ItemGroup>
		<Folder Include="Resources\" />
		<Folder Include="ViewModels\" />
	</ItemGroup>

	<ItemGroup>
		<Resource Include="Assets\Images\ArkPilotIcon.png">
			<CopyToOutputDirectory>Never</CopyToOutputDirectory>
		</Resource>

		<Resource Include="Assets\Images\ArkPilotLogo.png">
			<CopyToOutputDirectory>Never</CopyToOutputDirectory>
		</Resource>
	</ItemGroup>

</Project>