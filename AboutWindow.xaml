<Window x:Class="ArkPilot.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About ArkPilot"
        Height="550"
        Width="460"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#111827">

    <Grid Margin="25">

        <StackPanel HorizontalAlignment="Center">

            <Image Source="/Assets/Images/ArkPilotLogo.png"
                   Height="170"
                   Stretch="Uniform"/>

            <TextBlock Text="Version 12.8.0"
                       Margin="0,20,0,0"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center"/>

            <TextBlock Text="Founder's Edition"
                       FontSize="15"
                       Foreground="#FF8A00"
                       HorizontalAlignment="Center"/>

            <TextBlock Text="Control your ARK server."
                       Margin="0,15,0,0"
                       FontSize="14"
                       Foreground="#C9CDD3"
                       HorizontalAlignment="Center"/>

            <Separator Margin="0,25"/>

            <TextBlock Text="Developed by"
                       Foreground="#A0A0A0"
                       HorizontalAlignment="Center"/>

            <TextBlock Text="Damien Dechaume"
                       FontWeight="Bold"
                       FontSize="16"
                       Foreground="White"
                       HorizontalAlignment="Center"/>

            <TextBlock Text="© 2026 ArkPilot"
                       Margin="0,10,0,20"
                       Foreground="#A0A0A0"
                       HorizontalAlignment="Center"/>

            <Button Width="180"
                    Height="42"
                    Content="🌐 GitHub"
                    Click="Github_Click"/>

        </StackPanel>

    </Grid>

</Window>