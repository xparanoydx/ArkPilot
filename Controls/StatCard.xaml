<UserControl x:Class="ArkPilot.Controls.StatCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="220"
             MinHeight="120">

    <Border Background="{StaticResource BrushCard}"
            BorderBrush="{Binding AccentBrush, RelativeSource={RelativeSource AncestorType=UserControl}}"
            BorderThickness="1"
            CornerRadius="12"
            Padding="16"
            Margin="10">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0"
            Orientation="Horizontal">

                <TextBlock
        Text="{Binding Icon,
               RelativeSource={RelativeSource AncestorType=UserControl}}"
        FontSize="16"
        Margin="0,0,6,0"
        Foreground="{StaticResource BrushTextSecondary}"/>

                <TextBlock
        Text="{Binding Title,
               RelativeSource={RelativeSource AncestorType=UserControl}}"
        FontSize="15"
        FontWeight="SemiBold"
        Foreground="{StaticResource BrushTextSecondary}"/>

            </StackPanel>
            <TextBlock Grid.Row="1"
                       Foreground="{StaticResource BrushTextPrimary}"
                       FontSize="28"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Text="{Binding Value, RelativeSource={RelativeSource AncestorType=UserControl}}"/>

            <TextBlock Grid.Row="2"
                       Foreground="{StaticResource BrushTextSecondary}"
                       FontSize="12"
                       Text="{Binding Footer, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
        </Grid>

    </Border>
</UserControl>