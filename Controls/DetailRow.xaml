<UserControl x:Class="ArkPilot.Controls.DetailRow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             Height="24">

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="24"/>
            <ColumnDefinition Width="86"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Column="0"
                   Text="{Binding Icon, ElementName=Root}"
                   FontSize="14"
                   VerticalAlignment="Center"/>

        <TextBlock Grid.Column="1"
                   Text="{Binding Label, ElementName=Root}"
                   Style="{StaticResource DetailsLabelStyle}"/>

        <TextBlock Grid.Column="2"
                   Text="{Binding Value, ElementName=Root}"
                   Style="{StaticResource DetailsValueStyle}"/>

    </Grid>

</UserControl>