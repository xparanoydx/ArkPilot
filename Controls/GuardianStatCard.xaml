<UserControl x:Class="ArkPilot.Controls.GuardianStatCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">

    <Border
        Height="140"
        Padding="0"
        Background="{StaticResource BrushSurface1}"
        BorderBrush="{StaticResource BrushBorder}"
        BorderThickness="1"
        CornerRadius="{StaticResource RadiusLarge}">

        <Grid>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Barre d’accent -->
            <Border
                Grid.Column="0"
                Background="{Binding AccentBrush, ElementName=Root}"/>

            <!-- Contenu -->
            <StackPanel
                Grid.Column="1"
                Margin="{StaticResource SpacingLarge}"
                VerticalAlignment="Top">

                <TextBlock
                    FontSize="{Binding IconFontSize, ElementName=Root}"
                    Text="{Binding Icon, ElementName=Root}"/>

                <TextBlock
                    Margin="0,12,0,0"
                    FontSize="{StaticResource FontSizeTitle}"
                    FontWeight="{StaticResource FontWeightBold}"
                    Foreground="{Binding ValueBrush, ElementName=Root}"
                    Text="{Binding Value, ElementName=Root}"/>

                <TextBlock
                    Margin="0,6,0,0"
                    FontSize="{StaticResource FontSizeBody}"
                    Foreground="{StaticResource BrushTextSecondary}"
                    Text="{Binding Title, ElementName=Root}"/>

            </StackPanel>

        </Grid>

    </Border>

</UserControl>