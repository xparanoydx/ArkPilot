<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:guardian="clr-namespace:ArkPilot.Controls.Guardian">

    <Style TargetType="{x:Type guardian:GuardianPanel}">

        <Setter Property="Background"
            Value="Red"/>

        <Setter Property="Template">

            <Setter.Value>

                <ControlTemplate TargetType="{x:Type guardian:GuardianPanel}">

                    <Grid>

                        <Border
        Background="{DynamicResource GuardianBrush.Card}"
        BorderBrush="White"
        BorderThickness="2"
        CornerRadius="10"/>

                        <Border
        Margin="6"
        Background="Transparent"
        BorderBrush="#66FFFFFF"
        BorderThickness="1"
        CornerRadius="8"/>

                        <ContentPresenter
        Margin="20"/>

                    </Grid>
                    
                </ControlTemplate>

            </Setter.Value>

        </Setter>

    </Style>
    
</ResourceDictionary>