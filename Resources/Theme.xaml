<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Backgrounds -->
    <SolidColorBrush x:Key="BrushBackground" Color="#1E1E2E"/>
    <SolidColorBrush x:Key="BrushCard" Color="#2A2A3D"/>
    <SolidColorBrush x:Key="BrushCardHover" Color="#35354A"/>
    <SolidColorBrush x:Key="BrushBorder" Color="#40405A"/>

    <!-- Text -->
    <SolidColorBrush x:Key="BrushTextPrimary" Color="White"/>
    <SolidColorBrush x:Key="BrushTextSecondary" Color="#C0C0C0"/>

    <!-- Status -->
    <SolidColorBrush x:Key="BrushSuccess" Color="#4CAF50"/>
    <SolidColorBrush x:Key="BrushWarning" Color="#FF9800"/>
    <SolidColorBrush x:Key="BrushError" Color="#F44336"/>
    <SolidColorBrush x:Key="BrushInfo" Color="#42A5F5"/>

</ResourceDictionary>