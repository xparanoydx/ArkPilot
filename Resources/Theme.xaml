<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Backgrounds -->
    <SolidColorBrush x:Key="BrushBackground" Color="#1E1E2E"/>
    <SolidColorBrush x:Key="BrushCard" Color="#2A2A3D"/>
    <SolidColorBrush x:Key="BrushCardHover" Color="#35354A"/>
    <SolidColorBrush x:Key="BrushBorder" Color="#40405A"/>

    <!-- Text -->
    <SolidColorBrush x:Key="BrushTextPrimary" Color="White"/>
    <SolidColorBrush x:Key="BrushTextSecondary" Color="#C0C0C0"/>

    <!-- Status -->
    <SolidColorBrush x:Key="BrushSuccess" Color="#4CAF50"/>
    <SolidColorBrush x:Key="BrushWarning" Color="#FF9800"/>
    <SolidColorBrush x:Key="BrushError" Color="#F44336"/>
    <SolidColorBrush x:Key="BrushInfo" Color="#42A5F5"/>


    <!-- ========================= -->
    <!-- Couleurs des icônes -->
    <!-- ========================= -->

    <SolidColorBrush x:Key="BrushMale"
                 Color="#00B7FF"/>

    <SolidColorBrush x:Key="BrushFemale"
                 Color="#FF2EA6"/>

    <SolidColorBrush x:Key="BrushCryo"
                 Color="#5EDBFF"/>

    <SolidColorBrush x:Key="BrushMutation"
                 Color="#A855F7"/>

    <SolidColorBrush x:Key="BrushGps"
                 Color="#34D399"/>

    <SolidColorBrush x:Key="BrushInventory"
                 Color="#FBBF24"/>

    <SolidColorBrush x:Key="BrushHealth"
                 Color="#EF4444"/>

    <SolidColorBrush x:Key="BrushStamina"
                 Color="#FACC15"/>

    <SolidColorBrush x:Key="BrushFood"
                 Color="#FB923C"/>

    <SolidColorBrush x:Key="BrushWater"
                 Color="#38BDF8"/>


    <!-- ========================= -->
    <!-- Styles des fenêtres de détails -->
    <!-- ========================= -->

    <Style x:Key="DetailsLabelStyle"
       TargetType="TextBlock">

        <Setter Property="FontWeight"
            Value="SemiBold"/>

        <Setter Property="Foreground"
            Value="{StaticResource BrushTextSecondary}"/>

        <Setter Property="VerticalAlignment"
            Value="Center"/>

    </Style>

    <Style x:Key="DetailsValueStyle"
       TargetType="TextBlock">

        <Setter Property="Foreground"
            Value="{StaticResource BrushTextPrimary}"/>

        <Setter Property="VerticalAlignment"
            Value="Center"/>

    </Style>


    <!-- ========================= -->
    <!-- GLOBAL BUTTON STYLE -->
    <!-- ========================= -->

    <Style TargetType="Button">

        <Setter Property="Foreground"
            Value="{StaticResource BrushTextPrimary}"/>

        <Setter Property="Background"
            Value="{StaticResource BrushCard}"/>

        <Setter Property="BorderBrush"
            Value="{StaticResource BrushBorder}"/>

        <Setter Property="BorderThickness"
            Value="1"/>

        <Setter Property="Padding"
            Value="14,8"/>

        <Setter Property="FontWeight"
            Value="SemiBold"/>

        <Setter Property="Cursor"
            Value="Hand"/>


        <Setter Property="Template">

            <Setter.Value>

                <ControlTemplate TargetType="Button">

                    <Border x:Name="ButtonBorder"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="7"
                        Padding="{TemplateBinding Padding}">

                        <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>

                    </Border>


                    <ControlTemplate.Triggers>

                        <Trigger Property="IsMouseOver"
                             Value="True">

                            <Setter TargetName="ButtonBorder"
                                Property="Background"
                                Value="{StaticResource BrushCardHover}"/>

                        </Trigger>


                        <Trigger Property="IsPressed"
                             Value="True">

                            <Setter TargetName="ButtonBorder"
                                Property="Opacity"
                                Value="0.75"/>

                        </Trigger>


                        <Trigger Property="IsEnabled"
                             Value="False">

                            <Setter TargetName="ButtonBorder"
                                Property="Opacity"
                                Value="0.65"/>

                        </Trigger>

                    </ControlTemplate.Triggers>

                </ControlTemplate>

            </Setter.Value>

        </Setter>

    </Style>

</ResourceDictionary>