<Window x:Class="ArkPilot.Views.DinoDetailsWindow"
        xmlns:controls="clr-namespace:ArkPilot.Controls"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Détails du dinosaure"
        Width="620"
        Height="640"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BrushBackground}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">

        <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="24,22,24,20">
            
            <TextBlock Text="{Binding Species}"
               FontSize="24"
               FontWeight="Bold"
               Margin="0,0,0,8"
               Foreground="{StaticResource BrushTextPrimary}"/>

            <TextBlock Text="{Binding Name}"
               FontSize="14"
               Foreground="{StaticResource BrushTextSecondary}"/>

        </StackPanel>

        <StackPanel Grid.Row="2"
            Margin="24,0,24,20">
            
            <!-- Carte Informations générales -->
            <Border Background="{StaticResource BrushCard}"
                    BorderBrush="{StaticResource BrushBorder}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16"
                    Margin="0,0,0,12">

                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="24"/>
                        <RowDefinition Height="24"/>
                        <RowDefinition Height="24"/>
                        <RowDefinition Height="24"/>
                        <RowDefinition Height="24"/>

                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                   Grid.Column="0"
                   Grid.ColumnSpan="2"
                   Text="📋 Informations générales"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource BrushTextPrimary}"/>


                    <TextBlock Grid.Row="2"
                   Grid.Column="0"
                   Text="Sexe :"
                   Style="{StaticResource DetailsLabelStyle}"/>

                    <TextBlock Grid.Row="2"
                   Grid.Column="1"
                   Text="{Binding Gender}">

                        <TextBlock.Style>
                            <Style TargetType="TextBlock"
                       BasedOn="{StaticResource DetailsValueStyle}">

                                <Setter Property="FontSize"
                            Value="16"/>

                                <Setter Property="FontWeight"
                            Value="Bold"/>

                                <Style.Triggers>

                                    <DataTrigger Binding="{Binding Gender}"
                                     Value="♂">
                                        <Setter Property="Foreground"
                                    Value="{StaticResource BrushMale}"/>
                                    </DataTrigger>

                                    <DataTrigger Binding="{Binding Gender}"
                                     Value="♀">
                                        <Setter Property="Foreground"
                                    Value="{StaticResource BrushFemale}"/>
                                    </DataTrigger>

                                </Style.Triggers>

                            </Style>
                        </TextBlock.Style>

                    </TextBlock>

                    <TextBlock Grid.Row="3"
                   Grid.Column="0"
                   Text="Niveau :"
                   Style="{StaticResource DetailsLabelStyle}"/>

                    <TextBlock Grid.Row="3"
                   Grid.Column="1"
                   Text="{Binding Level}"
                   Style="{StaticResource DetailsValueStyle}"/>

                    <TextBlock Grid.Row="4"
                                Text="🌿 Niveau sauvage:"
                                Style="{StaticResource DetailsLabelStyle}" />

                    <TextBlock Grid.Row="4"
                                Grid.Column="1"
                                Text="{Binding BaseLevel}"
                                Style="{StaticResource DetailsValueStyle}" />

                    <TextBlock Grid.Row="5"
                   Grid.Column="0"
                   Text="Cryo :"
                   Style="{StaticResource DetailsLabelStyle}"/>

                    <TextBlock Grid.Row="5"
                   Grid.Column="1"
                   Text="{Binding CryoDisplay}"
                   Style="{StaticResource DetailsValueStyle}"
                   Foreground="{StaticResource BrushCryo}"
                   FontSize="15"/>

                    <TextBlock Grid.Row="6"
                                Text="🆔 ID Dino:"
                                Style="{StaticResource DetailsLabelStyle}" />

                    <TextBlock Grid.Row="6"
                                Grid.Column="1"
                                Text="{Binding DinoId}"
                                Style="{StaticResource DetailsValueStyle}" />


                </Grid>

            </Border>


            <!-- Carte Localisation -->
            <Border Background="{StaticResource BrushCard}"
        BorderBrush="{StaticResource BrushBorder}"
        BorderThickness="1"
        CornerRadius="8"
        Padding="16">

                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="24"/>
                        <RowDefinition Height="24"/>
                        <RowDefinition Height="24"/>
                        <RowDefinition Height="24"/>

                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                   Grid.Column="0"
                   Grid.ColumnSpan="2"
                   Text="📍 Localisation"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource BrushTextPrimary}"/>

                    <TextBlock Grid.Row="2"
                   Grid.Column="0"
                   Text="GPS :"
                   Style="{StaticResource DetailsLabelStyle}"/>

                    <TextBlock Grid.Row="2"
                   Grid.Column="1"
                   Text="{Binding Gps}"
                   Style="{StaticResource DetailsValueStyle}"/>

                    <TextBlock Grid.Row="3"
                   Grid.Column="0"
                   Text="Tribu :"
                   Style="{StaticResource DetailsLabelStyle}"/>

                    <TextBlock Grid.Row="3"
                   Grid.Column="1"
                   Text="{Binding TribeName}"
                   Style="{StaticResource DetailsValueStyle}"/>

                    <TextBlock Grid.Row="4"
                                Text="🆔 ID Tribu:"
                                Style="{StaticResource DetailsLabelStyle}" />

                    <TextBlock Grid.Row="4"
                                Grid.Column="1"
                                Text="{Binding TribeId}"
                                Style="{StaticResource DetailsValueStyle}" />

                    <TextBlock Grid.Row="5"
                   Grid.Column="0"
                   Text="Propriétaire :"
                   Style="{StaticResource DetailsLabelStyle}"/>

                    <TextBlock Grid.Row="5"
                   Grid.Column="1"
                   Text="{Binding OwnerName}"
                   Style="{StaticResource DetailsValueStyle}"/>

                </Grid>

            </Border>

        </StackPanel>
    </Grid>

    </ScrollViewer>

</Window>