<Page x:Class="ArkPilot.Views.ConsolePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#1E1E2E">

    <Grid Margin="30">

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>


        <!-- LOG CONSOLE -->
        <Border Background="#2A2A3D"
                CornerRadius="10"
                Padding="10">

            <ListBox x:Name="ConsoleList"
                     Background="#1E1E2E"
                     Foreground="White"
                     FontFamily="Consolas"/>
        </Border>



        <!-- COMMANDES -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Margin="0,15,0,0">


            <TextBox x:Name="CommandBox"
                     Width="500"
                     Height="35"
                     Background="#2A2A3D"
                     Foreground="White"
                     Margin="0,0,10,0"/>


            <Button Content="▶ Envoyer"
                    Width="120"
                    Height="35"
                    Margin="0,0,10,0"
                    Click="SendCommand_Click"/>


            <Button Content="🗑 Effacer"
                    Width="120"
                    Height="35"
                    Click="Clear_Click"/>

        </StackPanel>

    </Grid>

</Page>