<Window x:Class="ArkPilot.Views.GuardianDashboardMockup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Guardian Dashboard"
        Width="1600"
        Height="900"
        Background="#070C14"
        WindowStartupLocation="CenterScreen">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="20"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Grid.ColumnSpan="2"
                Margin="6"
                Background="#121E2B"
                BorderBrush="#274A63"
                BorderThickness="2"/>

        <!-- Sidebar -->
        <Border Grid.Row="1"
                Margin="6"
                Background="#111A27"
                BorderBrush="#274A63"
                BorderThickness="2"/>

        <!-- Dashboard -->
        <Border Grid.Row="1"
        Grid.Column="1"
        Margin="6"
        Background="#101923"
        BorderBrush="#274A63"
        BorderThickness="2"
        Padding="20">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="110"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="180"/>
                </Grid.RowDefinitions>

                <!-- Cartes statistiques -->
                <UniformGrid Grid.Row="0"
                     Columns="4"
                     Margin="0,0,0,16">

                    <Border Style="{StaticResource GuardianPanelStyle}"/>
                    <Border Style="{StaticResource GuardianPanelStyle}"/>
                    <Border Style="{StaticResource GuardianPanelStyle}"/>
                    <Border Style="{StaticResource GuardianPanelStyle}"/>

                </UniformGrid>

                <!-- Graphique -->
                <Border Grid.Row="1"
                Style="{StaticResource GuardianPanelStyle}"
                Margin="0,0,0,16"/>

                <!-- Bas -->
                <Grid Grid.Row="2">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                    Style="{StaticResource GuardianPanelStyle}"
                    Margin="0,0,8,0"/>

                    <Border Grid.Column="1"
                    Style="{StaticResource GuardianPanelStyle}"
                    Margin="8,0,0,0"/>

                </Grid>

            </Grid>

        </Border>
        
        <!-- Status -->
        <Border Grid.Row="2"
                Grid.ColumnSpan="2"
                Margin="6"
                Background="#121E2B"
                BorderBrush="#274A63"
                BorderThickness="2"/>

    </Grid>

</Window>