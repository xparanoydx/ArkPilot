    <Page x:Class="ArkPilot.Views.DinosPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BrushBackground}">

        <Page.Resources>

            <Style x:Key="CenteredDataGridText"
               TargetType="TextBlock">

                <Setter Property="HorizontalAlignment"
                    Value="Stretch"/>

                <Setter Property="TextAlignment"
                    Value="Center"/>

                <Setter Property="VerticalAlignment"
                    Value="Center"/>

            </Style>

        </Page.Resources>

            <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">

            <TextBox x:Name="SearchBox"
             Style="{StaticResource SearchTextBoxStyle}"
             TextChanged="SearchBox_TextChanged"/>

            <TextBlock Text="🔍 Rechercher une espèce, un nom, une tribu ou un propriétaire..."
               Margin="10,0,0,10"
               VerticalAlignment="Center"
               Foreground="{StaticResource BrushTextSecondary}"
               IsHitTestVisible="False">

                <TextBlock.Style>
                    <Style TargetType="TextBlock">

                        <Setter Property="Visibility"
                        Value="Collapsed"/>

                        <Style.Triggers>

                            <DataTrigger Binding="{Binding Text, ElementName=SearchBox}"
                                 Value="">

                                <Setter Property="Visibility"
                                Value="Visible"/>

                            </DataTrigger>

                        </Style.Triggers>

                    </Style>
                </TextBlock.Style>

            </TextBlock>

        </Grid>
        
        <TextBlock x:Name="CountText"
               Grid.Row="1"
               Margin="2,0,0,8"
               Foreground="{StaticResource BrushTextSecondary}"
               FontSize="12"
               Text="0 dinosaure"/>

        <DataGrid x:Name="DinosGrid"
              Style="{StaticResource ModernDataGridStyle}"
              Grid.Row="3"
              AutoGenerateColumns="False"
              IsReadOnly="True"
              CanUserAddRows="False"
              SelectionMode="Single"
              MouseDoubleClick="DinosGrid_MouseDoubleClick">

            <DataGrid.Columns>

                <DataGridTextColumn Header="Espèce"
                                Binding="{Binding Species}"
                                Width="140"/>

                <DataGridTextColumn Header="Nom"
                                    Binding="{Binding Name}"
                                    Width="140"/>


                <DataGridTemplateColumn Header="Sexe"
                        Width="55">

                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>

                            <TextBlock Text="{Binding Gender}"
                       FontSize="16"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center">

                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">

                                        <Setter Property="Foreground"
                                Value="{StaticResource BrushMale}"/>

                                        <Style.Triggers>

                                            <DataTrigger Binding="{Binding Gender}"
                                         Value="♀">

                                                <Setter Property="Foreground"
                                        Value="{StaticResource BrushFemale}"/>

                                            </DataTrigger>

                                        </Style.Triggers>

                                    </Style>
                                </TextBlock.Style>

                            </TextBlock>

                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>

                </DataGridTemplateColumn>
                

                <DataGridTextColumn Header="Niveau"
                    Binding="{Binding Level}"
                    Width="70"
                    ElementStyle="{StaticResource CenteredDataGridText}"/>

                    <DataGridTextColumn Header="GPS"
                    Binding="{Binding Gps}"
                    Width="90"
                    ElementStyle="{StaticResource CenteredDataGridText}"/>

                    <DataGridTextColumn Header="Tribu"
                                Binding="{Binding TribeName}"
                                Width="180"/>

                <DataGridTextColumn Header="Propriétaire"
                                Binding="{Binding OwnerName}"
                                Width="170"/>

                    <DataGridTextColumn Header="Cryo"
                    Binding="{Binding CryoDisplay}"
                    Width="55"
                    IsReadOnly="True"
                    ElementStyle="{StaticResource CenteredDataGridText}"/>

                </DataGrid.Columns>

        </DataGrid>

    </Grid>
        
</Page>