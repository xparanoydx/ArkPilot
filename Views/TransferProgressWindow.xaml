<Window x:Class="ArkPilot.Views.TransferProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Transfert"
        Height="220"
        Width="500"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BrushBackground}">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TitleText"
                   Text="Téléchargement..."
                   FontSize="22"
                   FontWeight="Bold"
                   Foreground="{StaticResource BrushTextPrimary}"/>

        <TextBlock x:Name="FileText"
                   Grid.Row="1"
                   Margin="0,12,0,12"
                   FontSize="15"
                   Foreground="{StaticResource BrushTextSecondary}"/>

        <ProgressBar x:Name="Progress"
                     Grid.Row="2"
                     Height="24"
                     Minimum="0"
                     Maximum="100"/>

        <TextBlock x:Name="PercentText"
                   Grid.Row="3"
                   Margin="0,15,0,0"
                   HorizontalAlignment="Center"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource BrushTextPrimary}"/>

    </Grid>

</Window>