<Page x:Class="ArkPilot.Views.ChatPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BrushBackground}">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
              HorizontalScrollBarVisibility="Disabled">

        <Grid Margin="30">
            <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="280"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- HEADER -->
        <StackPanel>
            <TextBlock Text="Messages serveur"
                       FontSize="30"
                       FontWeight="Bold"
                       Foreground="{StaticResource BrushTextPrimary}"/>

            <TextBlock Text="Consulter le chat du serveur et envoyer des messages aux joueurs"
                       FontSize="14"
                       Foreground="{StaticResource BrushTextSecondary}"/>
        </StackPanel>

        <!-- CHAT SERVER -->
        <Border Grid.Row="1"
        Background="{StaticResource BrushCard}"
        BorderBrush="{StaticResource BrushBorder}"
        BorderThickness="1"
        CornerRadius="12"
        Padding="16"
        Margin="0,25,0,15">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>


                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>


                    <TextBlock Text="💬 Chat serveur"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource BrushTextPrimary}"/>


                    <TextBlock x:Name="ChatStatusText"
                       Grid.Column="1"
                       Text="🟡 Chargement..."
                       Foreground="{StaticResource BrushTextSecondary}"
                       VerticalAlignment="Center"/>

                </Grid>


                <ListBox x:Name="ChatList"
                 Grid.Row="1"
                 Margin="0,15,0,0"
                 Background="{StaticResource BrushBackground}"
                 Foreground="{StaticResource BrushTextPrimary}"
                 BorderBrush="{StaticResource BrushBorder}"
                 BorderThickness="1"
                 Padding="8"
                 FontFamily="Consolas"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>

            </Grid>

        </Border>


        <!-- BROADCAST CARD -->
        <Border Grid.Row="2"
                Background="{StaticResource BrushCard}"
                BorderBrush="{StaticResource BrushBorder}"
                VerticalAlignment="Top"
                BorderThickness="1"
                CornerRadius="12"
                Padding="20"
                Margin="0,25,0,0">

            <StackPanel>

                <TextBlock Text="📢 Broadcast"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource BrushTextPrimary}"
                           Margin="0,0,0,15"/>

                <TextBox x:Name="BroadcastMessageBox"
                         Height="100"
                         MaxLength="200"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Background="{StaticResource BrushBackground}"
                         Foreground="{StaticResource BrushTextPrimary}"
                         BorderBrush="{StaticResource BrushBorder}"
                         TextChanged="BroadcastMessageBox_TextChanged"
                         BorderThickness="1"
                         Padding="10"/>

                <TextBlock x:Name="CharacterCountText"
                            Text="0 caractère"
                            FontSize="12"
                            Foreground="{StaticResource BrushTextSecondary}"
                            HorizontalAlignment="Right"
                            Margin="0,6,0,0"/>

                <Button Content="📢 Envoyer le Broadcast"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Width="220"
                        HorizontalAlignment="Left"
                        Margin="0,15,0,0"
                        Click="SendBroadcast_Click"/>

                <TextBlock Text="Messages rapides"
                            FontSize="18"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource BrushTextPrimary}"
                            Margin="0,25,0,10"/>

                <WrapPanel>

                    <Button Content="⏳ Redémarrage 15 min"
                            Margin="0,0,10,10"
                            Padding="12,8"
                            Tag="Le serveur redemarrera dans 15 minutes."
                            Click="QuickMessage_Click"/>

                    <Button Content="⏳ Redémarrage 5 min"
                            Margin="0,0,10,10"
                            Padding="12,8"
                            Tag="Le serveur redemarrera dans 5 minutes."
                            Click="QuickMessage_Click"/>

                    <Button Content="💾 Sauvegarde"
                            Margin="0,0,10,10"
                            Padding="12,8"
                            Tag="Sauvegarde du serveur en cours."
                            Click="QuickMessage_Click"/>

                    <Button Content="🎉 Événement actif"
                            Margin="0,0,10,10"
                            Padding="12,8"
                            Tag="Un evenement serveur est actuellement actif !"
                            Click="QuickMessage_Click"/>

                    <Button Content="🔧 Maintenance"
                            Margin="0,0,10,10"
                            Padding="12,8"
                            Tag="Une maintenance du serveur est en cours."
                            Click="QuickMessage_Click"/>

                    <Button Content="✅ Serveur disponible"
                            Margin="0,0,10,10"
                            Padding="12,8"
                            Tag="Le serveur est de nouveau disponible. Bon jeu a tous !"
                            Click="QuickMessage_Click"/>

                </WrapPanel>

            </StackPanel>

        </Border>

    </Grid>

    </ScrollViewer>

</Page>