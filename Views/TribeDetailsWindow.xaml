<Window x:Class="ArkPilot.Views.TribeDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fiche tribu"
        Width="650"
        Height="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BrushBackground}">

    <Grid Margin="25">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>


        <!-- HEADER -->
        <StackPanel>

            <TextBlock Text="🏰 Fiche tribu"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="{StaticResource BrushTextPrimary}"/>

            <TextBlock Text="Informations et membres de la tribu"
                       FontSize="14"
                       Foreground="{StaticResource BrushTextSecondary}"/>

        </StackPanel>


        <!-- INFORMATIONS -->
        <Border Grid.Row="1"
                Background="{StaticResource BrushCard}"
                BorderBrush="{StaticResource BrushBorder}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="18"
                Margin="0,20,0,15">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>


                <TextBlock Text="Nom"
                           Foreground="{StaticResource BrushTextSecondary}"/>

                <TextBlock x:Name="TribeNameText"
                           Grid.Column="1"
                           Foreground="{StaticResource BrushTextPrimary}"
                           FontWeight="SemiBold"/>


                <TextBlock Grid.Row="1"
                           Text="ID tribu"
                           Foreground="{StaticResource BrushTextSecondary}"
                           Margin="0,12,0,0"/>

                <TextBlock x:Name="TribeIdText"
                           Grid.Row="1"
                           Grid.Column="1"
                           Foreground="{StaticResource BrushTextPrimary}"
                           Margin="0,12,0,0"/>


                <TextBlock Grid.Row="2"
                           Text="Membres"
                           Foreground="{StaticResource BrushTextSecondary}"
                           Margin="0,12,0,0"/>

                <TextBlock x:Name="TribeMemberCountText"
                           Grid.Row="2"
                           Grid.Column="1"
                           Foreground="{StaticResource BrushTextPrimary}"
                           Margin="0,12,0,0"/>

            </Grid>

        </Border>


        <!-- MEMBERS -->
        <Border Grid.Row="2"
                Background="{StaticResource BrushCard}"
                BorderBrush="{StaticResource BrushBorder}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="18">

            <StackPanel>

                <TextBlock Text="👥 Membres de la tribu"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource BrushTextPrimary}"
                           Margin="0,0,0,12"/>

                <DataGrid x:Name="TribeMembersGrid"
                          Style="{StaticResource ModernDataGridStyle}"
                          ItemsSource="{Binding}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          HeadersVisibility="Column"
                          Background="{StaticResource BrushBackground}"
                          Foreground="{StaticResource BrushTextPrimary}"
                          BorderBrush="{StaticResource BrushBorder}"
                          BorderThickness="1">

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="Personnage"
                            Binding="{Binding CharacterName}"
                            Width="*"/>

                        <DataGridTextColumn Header="Joueur"
                            Binding="{Binding PlayerName}"
                            Width="*"/>

                        <DataGridTextColumn Header="Niveau"
                            Binding="{Binding Level}"
                            Width="80"/>

                        <DataGridCheckBoxColumn Header="Propriétaire"
                                Binding="{Binding IsOwner}"
                                Width="100"/>

                    </DataGrid.Columns>

                </DataGrid>
            </StackPanel>

        </Border>


        <!-- CLOSE -->
        <Button Grid.Row="3"
                Content="Fermer"
                Width="120"
                HorizontalAlignment="Right"
                Margin="0,15,0,0"
                Click="Close_Click"/>

    </Grid>

</Window>