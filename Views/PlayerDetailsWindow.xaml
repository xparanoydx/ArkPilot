<Window x:Class="ArkPilot.Views.PlayerDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fiche joueur"
        Width="650"
        Height="840"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BrushBackground}">

    <Grid Margin="25">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>


        <!-- HEADER -->
        <StackPanel>

            <TextBlock Text="👤 Fiche joueur"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="{StaticResource BrushTextPrimary}"/>

            <TextBlock Text="Informations et actions d'administration"
                       FontSize="14"
                       Foreground="{StaticResource BrushTextSecondary}"/>

        </StackPanel>


        <!-- INFORMATIONS -->
        <Border Grid.Row="1"
                Background="{StaticResource BrushCard}"
                BorderBrush="{StaticResource BrushBorder}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="18"
                Margin="0,20,0,15">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>


                <TextBlock Text="Nom"
                           Foreground="{StaticResource BrushTextSecondary}"/>

                <TextBlock x:Name="PlayerNameText"
                           Grid.Column="1"
                           Foreground="{StaticResource BrushTextPrimary}"
                           FontWeight="SemiBold"/>


                <TextBlock Grid.Row="1"
                           Text="EOS / Steam ID"
                           Foreground="{StaticResource BrushTextSecondary}"
                           Margin="0,12,0,0"/>

                <TextBlock x:Name="PlayerIdText"
                           Grid.Row="1"
                           Grid.Column="1"
                           Foreground="{StaticResource BrushTextPrimary}"
                           Margin="0,12,0,0"
                           TextWrapping="Wrap"/>


                <TextBlock Grid.Row="2"
                           Text="Tribu"
                           Foreground="{StaticResource BrushTextSecondary}"
                           Margin="0,12,0,0"/>

                <TextBlock x:Name="PlayerTribeText"
                           Grid.Row="2"
                           Grid.Column="1"
                           Foreground="{StaticResource BrushTextPrimary}"
                           Margin="0,12,0,0"/>


                <TextBlock Grid.Row="3"
                           Text="Niveau"
                           Foreground="{StaticResource BrushTextSecondary}"
                           Margin="0,12,0,0"/>

                <TextBlock x:Name="PlayerLevelText"
                           Grid.Row="3"
                           Grid.Column="1"
                           Foreground="{StaticResource BrushTextPrimary}"
                           Margin="0,12,0,0"/>

            </Grid>

        </Border>


        <!-- NOTE ADMIN -->
        <Border Grid.Row="2"
                Background="{StaticResource BrushCard}"
                BorderBrush="{StaticResource BrushBorder}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="18">

            <StackPanel>

                <TextBlock Text="📝 Note administrateur"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource BrushTextPrimary}"
                           Margin="0,0,0,12"/>

                <TextBox x:Name="PlayerNoteBox"
                         Height="110"
                         MaxLength="500"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Background="{StaticResource BrushBackground}"
                         Foreground="{StaticResource BrushTextPrimary}"
                         BorderBrush="{StaticResource BrushBorder}"
                         BorderThickness="1"
                         Padding="10"/>

                <Button Content="💾 Enregistrer la note"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Width="200"
                        HorizontalAlignment="Left"
                        Margin="0,12,0,0"
                        Click="SaveNote_Click"/>

                <Button Content="🗑 Supprimer la note"
                        Width="200"
                        HorizontalAlignment="Left"
                        Margin="0,8,0,0"
                        Click="DeleteNote_Click"/>

            </StackPanel>

        </Border>


        <!-- ACTIONS -->
        <Border Grid.Row="3"
                Background="{StaticResource BrushCard}"
                BorderBrush="{StaticResource BrushBorder}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="18"
                Margin="0,15,0,15">

            <StackPanel>

                <TextBlock Text="🛡 Actions administrateur"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource BrushTextPrimary}"
                           Margin="0,0,0,12"/>

                <WrapPanel>

                    <Button Content="👢 Kick"
                            Width="120"
                            Margin="0,0,10,10"
                            Click="Kick_Click"/>

                    <Button Content="🔨 Ban"
                            Width="120"
                            Margin="0,0,10,10"
                            Click="Ban_Click"/>


                    <Button Content="📋 Copier ID"
                            Width="140"
                            Margin="0,0,10,10"
                            Click="CopyId_Click"/>

                </WrapPanel>

            </StackPanel>

        </Border>


        <!-- CLOSE -->
        <Button Grid.Row="4"
                Content="Fermer"
                Width="120"
                HorizontalAlignment="Right"
                Click="Close_Click"/>

    </Grid>

</Window>