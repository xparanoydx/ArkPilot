<Window x:Class="ArkPilot.Views.Guardian.GuardianShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GuardianShell"
        Width="1600"
        Height="900"

        WindowStyle="None"
        ResizeMode="CanResize"
        Background="Transparent"
        AllowsTransparency="True">

    <Grid Background="#0A1018">

        <!-- Fenêtre principale -->
        <Border
            Margin="12"
            Background="#101A24"
            BorderBrush="#27D7FF"
            BorderThickness="2"
            CornerRadius="10">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="72"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Header -->
                <Border
                    Grid.ColumnSpan="2"
                    Background="#162432"
                    BorderBrush="#27D7FF"
                    BorderThickness="0,0,0,1">

                    <Grid>

                        <TextBlock
                            Text="ARKPILOT"
                            FontSize="28"
                            FontWeight="Bold"
                            Foreground="White"
                            VerticalAlignment="Center"
                            Margin="24,0"/>

                    </Grid>

                </Border>

                <!-- Sidebar -->
                <Border
                    Grid.Row="1"
                    Background="#111A25"
                    BorderBrush="#27D7FF"
                    BorderThickness="0,1,1,0"/>

                <!-- Zone centrale -->
                <Border
                    Grid.Row="1"
                    Grid.Column="1"
                    Margin="20"
                    Background="#162432"
                    BorderBrush="#27D7FF"
                    BorderThickness="1"/>

            </Grid>

        </Border>

    </Grid>

</Window>