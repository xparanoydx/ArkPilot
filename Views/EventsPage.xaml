<Page x:Class="ArkPilot.Views.EventsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#1E1E2E">

    <ScrollViewer VerticalScrollBarVisibility="Auto">

        <StackPanel Margin="30"
                    Width="560">

            <TextBlock Text="🎉 Événements automatiques"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="White"
                       Margin="0,0,0,10"/>

            <TextBlock Text="Configure les bonus automatiques du week-end."
                       Foreground="#B8B8C8"
                       Margin="0,0,0,25"/>

            <Border Background="#181827"
        CornerRadius="8"
        Padding="15"
        Margin="0,0,0,20">

                <StackPanel>

                    <TextBlock Text="📅 Période de l'événement"
                   Foreground="White"
                   FontSize="16"
                   FontWeight="Bold"
                   Margin="0,0,0,10"/>

                    <TextBlock x:Name="WeekendPeriodText"
                   Foreground="#B8B8C8"
                   Text="Début : --&#x0a;Fin : --"
                   Margin="0,0,0,15"/>


                    <TextBlock Text="Début"
                   Foreground="White"
                   FontWeight="Bold"
                   Margin="0,0,0,5"/>

                    <Grid Margin="0,0,0,15">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="70"/>
                        </Grid.ColumnDefinitions>

                        <ComboBox x:Name="WeekendStartDayBox"
                      Grid.Column="0"
                      Height="35">

                            <ComboBoxItem Content="Dimanche"/>
                            <ComboBoxItem Content="Lundi"/>
                            <ComboBoxItem Content="Mardi"/>
                            <ComboBoxItem Content="Mercredi"/>
                            <ComboBoxItem Content="Jeudi"/>
                            <ComboBoxItem Content="Vendredi"/>
                            <ComboBoxItem Content="Samedi"/>

                        </ComboBox>

                        <TextBox x:Name="WeekendStartHourBox"
                     Grid.Column="1"
                     Height="35"
                     Margin="10,0,0,0"/>

                        <TextBlock Grid.Column="2"
                       Text=":"
                       Foreground="White"
                       FontSize="20"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

                        <TextBox x:Name="WeekendStartMinuteBox"
                     Grid.Column="3"
                     Height="35"/>

                    </Grid>


                    <TextBlock Text="Fin"
                   Foreground="White"
                   FontWeight="Bold"
                   Margin="0,0,0,5"/>

                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="70"/>
                        </Grid.ColumnDefinitions>

                        <ComboBox x:Name="WeekendEndDayBox"
                      Grid.Column="0"
                      Height="35">

                            <ComboBoxItem Content="Dimanche"/>
                            <ComboBoxItem Content="Lundi"/>
                            <ComboBoxItem Content="Mardi"/>
                            <ComboBoxItem Content="Mercredi"/>
                            <ComboBoxItem Content="Jeudi"/>
                            <ComboBoxItem Content="Vendredi"/>
                            <ComboBoxItem Content="Samedi"/>

                        </ComboBox>

                        <TextBox x:Name="WeekendEndHourBox"
                     Grid.Column="1"
                     Height="35"
                     Margin="10,0,0,0"/>

                        <TextBlock Grid.Column="2"
                       Text=":"
                       Foreground="White"
                       FontSize="20"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

                        <TextBox x:Name="WeekendEndMinuteBox"
                     Grid.Column="3"
                     Height="35"/>

                    </Grid>

                </StackPanel>

            </Border>

            <Border Background="#2A2A3D"
                    CornerRadius="8"
                    Padding="20">

                <StackPanel>

                    <CheckBox x:Name="WeekendEventBox"
                        Content="Activer l'événement week-end"
                        Foreground="White"
                        FontSize="16"
                        Margin="0,0,0,20"
                        Checked="WeekendEventBox_Changed"
                        Unchecked="WeekendEventBox_Changed"/>
                    
                    <StackPanel x:Name="WeekendOptionsPanel">

                    <TextBlock Text="Multiplicateur Taming"
                        Foreground="White"/>

                    <Grid Margin="0,5,0,15">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <CheckBox x:Name="WeekendTamingEnabledBox"
                            Grid.Column="0"
                            Content="ON"
                            Foreground="White"
                            VerticalAlignment="Center"/>

                        <TextBox x:Name="WeekendTamingBox"
                            Grid.Column="1"
                            Height="35"/>

                    </Grid>
                    

                    <TextBlock Text="Wild Dino Food Drain"
                        Foreground="White"/>

                    <Grid Margin="0,5,0,15">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <CheckBox x:Name="WeekendWildDinoFoodDrainEnabledBox"
                            Grid.Column="0"
                            Content="ON"
                            Foreground="White"
                            VerticalAlignment="Center"/>

                        <TextBox x:Name="WeekendWildDinoFoodDrainBox"
                            Grid.Column="1"
                            Height="35"/>

                    </Grid>
                    

                    <TextBlock Text="Multiplicateur Récolte"
                        Foreground="White"/>

                    <Grid Margin="0,5,0,15">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <CheckBox x:Name="WeekendHarvestEnabledBox"
                            Grid.Column="0"
                            Content="ON"
                            Foreground="White"
                            VerticalAlignment="Center"/>

                        <TextBox x:Name="WeekendHarvestBox"
                            Grid.Column="1"
                            Height="35"/>

                    </Grid>


                    <TextBlock Text="Multiplicateur Croissance bébés"
                         Foreground="White"/>

                    <Grid Margin="0,5,0,15">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <CheckBox x:Name="WeekendBabyMatureEnabledBox"
                            Grid.Column="0"
                            Content="ON"
                            Foreground="White"
                            VerticalAlignment="Center"/>

                        <TextBox x:Name="WeekendBabyMatureBox"
                            Grid.Column="1"
                            Height="35"/>

                    </Grid>


                    <TextBlock Text="Intervalle câlins bébés"
                        Foreground="White"/>

                    <Grid Margin="0,5,0,20">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <CheckBox x:Name="WeekendBabyCuddleIntervalEnabledBox"
                            Grid.Column="0"
                            Content="ON"
                            Foreground="White"
                            VerticalAlignment="Center"/>

                        <TextBox x:Name="WeekendBabyCuddleIntervalBox"
                            Grid.Column="1"
                            Height="35"/>

                    </Grid>
                    

                    <TextBlock Text="Multiplicateur XP"
                        Foreground="White"/>

                    <Grid Margin="0,5,0,15">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <CheckBox x:Name="WeekendXpEnabledBox"
                            Grid.Column="0"
                            Content="ON"
                            Foreground="White"
                            VerticalAlignment="Center"/>

                        <TextBox x:Name="WeekendXpBox"
                            Grid.Column="1"
                            Height="35"/>

                    </Grid>

                    </StackPanel>

                    <Button x:Name="SetOriginalConfigButton"
                            Width="300"
                            Height="40"
                            HorizontalAlignment="Left"
                            Margin="0,0,0,10"
                            Content="📌 Définir la configuration actuelle comme origine"
                            Click="SetOriginalConfig_Click"/>


                    <Button x:Name="SaveEventButton"
                            Width="180"
                            Height="40"
                            HorizontalAlignment="Left"
                            Content="💾 Sauvegarder"
                            Click="SaveEvent_Click"/>


                    <Border Margin="0,20,0,0"
                            Background="#181827"
                            CornerRadius="6"
                            Padding="10">

                        <TextBlock x:Name="StatusText"
                                   Foreground="LightGreen"
                                   Text="Prêt."/>

                    </Border>

                </StackPanel>

            </Border>

        </StackPanel>

    </ScrollViewer>

</Page>