<Page x:Class="ArkPilot.Views.TribesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BrushBackground}">

    <Grid Margin="30">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>


        <!-- HEADER -->
        <StackPanel>
            <TextBlock Text="Tribus"
                       FontSize="30"
                       FontWeight="Bold"
                       Foreground="{StaticResource BrushTextPrimary}"/>

            <TextBlock Text="Gestion et consultation des tribus du serveur"
                       FontSize="14"
                       Foreground="{StaticResource BrushTextSecondary}"/>
        </StackPanel>


        <!-- TOOLBAR -->
        <Border Grid.Row="1"
                Background="{StaticResource BrushCard}"
                BorderBrush="{StaticResource BrushBorder}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="16"
                Margin="0,25,0,15">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="SearchBox"
                         Width="260"
                         Height="38"
                         ToolTip="Rechercher une tribu..."
                         Background="{StaticResource BrushBackground}"
                         Foreground="{StaticResource BrushTextPrimary}"
                         BorderBrush="{StaticResource BrushBorder}"
                         BorderThickness="1"/>

                <TextBlock x:Name="TribeCountText"
                           Grid.Column="1"
                           Text="🏰 Tribus : 0"
                           Foreground="{StaticResource BrushTextPrimary}"
                           VerticalAlignment="Center"
                           Margin="20,0,0,0"/>

                <Button Grid.Column="2"
                        Content="🔄 Actualiser"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Width="170"
                        Click="RefreshTribes_Click"/>
            </Grid>

        </Border>


        <!-- TRIBES GRID -->
        <DataGrid x:Name="TribesGrid"
                  Grid.Row="2"
                  Style="{StaticResource ModernDataGridStyle}"
                  AutoGenerateColumns="False"
                  MouseDoubleClick="TribesGrid_MouseDoubleClick">

            <DataGrid.Columns>

                <DataGridTextColumn Header="Nom de la tribu"
                                    Binding="{Binding Name}"
                                    Width="*"/>

                <DataGridTextColumn Header="ID tribu"
                                    Binding="{Binding Id}"
                                    Width="220"/>

                <DataGridTextColumn Header="Membres"
                                    Binding="{Binding MemberCount}"
                                    Width="120"/>

            </DataGrid.Columns>

        </DataGrid>

    </Grid>

</Page>