<Window
    x:Class="ArkPilot.Views.GuardianShowroomWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:guardian="clr-namespace:Guardian.Controls.Controls;assembly=Guardian.UI"
    Title="Guardian Preview"
    Width="1000"
    Height="700">

    <Grid Background="{DynamicResource GuardianBrush.Background}">

        <guardian:GuardianFrame
    Width="420"
    Height="220"
    Padding="24"
    HorizontalAlignment="Center"
    VerticalAlignment="Center">

            <TextBlock
        Text="GuardianFrame"
        Foreground="{DynamicResource GuardianBrush.Text}"
        FontSize="18"
        FontWeight="SemiBold"
        HorizontalAlignment="Center"
        VerticalAlignment="Center"/>

        </guardian:GuardianFrame>
        
    </Grid>

</Window>