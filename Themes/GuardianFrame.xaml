<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:ArkPilot.Controls">

    <Style TargetType="{x:Type controls:GuardianFrame}">

        <Setter Property="Background"
        Value="{DynamicResource GuardianBrush.Card}" />

        <Setter Property="BorderBrush"
        Value="{DynamicResource GuardianBrush.Border}" />
        
        <Setter Property="BorderThickness"
                Value="1" />

        <Setter Property="Padding"
                Value="16" />

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:GuardianFrame}">

                    <Grid>

                        <!-- Guardian Shape -->
                        <Grid x:Name="ShapeLayer"
      IsHitTestVisible="False">

                            <Path
        Stretch="Fill"
        Stroke="{DynamicResource GuardianBrush.Accent}"
        StrokeThickness="1.5"
        Data="M 18,0
              L 282,0
              L 300,18
              L 300,132
              L 282,150
              L 18,150
              L 0,132
              L 0,18
              Z"/>

                        </Grid>
                        
                        <!-- Couche 1 : Glow  -->
                        <Grid x:Name="GlowLayer"
      IsHitTestVisible="False">

                            <!-- Halo externe -->
                            <Border
        Margin="-2"
        CornerRadius="14"
        BorderBrush="#1022D6FF"
        BorderThickness="2"/>

                            <!-- Halo interne -->
                            <Border
        Margin="-1"
        CornerRadius="13"
        BorderBrush="#1822D6FF"
        BorderThickness="1"/>

                        </Grid>
                        
                        <!-- Couche 2 : Cadre -->
                        <Border
            Background="{TemplateBinding Background}"
            BorderBrush="#284A63"
            BorderThickness="1"
            CornerRadius="12">

                            <Border
                Margin="1"
                BorderBrush="#20384D"
                BorderThickness="1"
                CornerRadius="11">

                                <!-- Couche 3 : Fond -->
                                <Grid>

                                    <!-- Décorations Guardian -->
                                    <Grid x:Name="DecorationLayer"
                                            IsHitTestVisible="False">

                                        <controls:GuardianCorner
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Top"/>

                                    </Grid>
                                    <!-- Contenu -->
                                    <ContentPresenter
                        Margin="{TemplateBinding Padding}"/>

                                </Grid>

                            </Border>

                        </Border>

                    </Grid>

                </ControlTemplate>
                
            </Setter.Value>
        </Setter>

    </Style>

</ResourceDictionary>