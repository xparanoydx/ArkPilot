<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:ArkPilot.Controls">
    

    <Style TargetType="{x:Type controls:GuardianCorner}">

        <Setter Property="Width"
        Value="48" />

        <Setter Property="Height"
        Value="48" />
        
        <Setter Property="Template">
            <Setter.Value>

                <ControlTemplate TargetType="{x:Type controls:GuardianCorner}">

                    <Canvas
        Width="{StaticResource GuardianCorner.Size}"
        Height="{StaticResource GuardianCorner.Size}"
                ClipToBounds="False"
                Background="Transparent">

                        <!-- Segment horizontal principal -->

                        <Rectangle
    Style="{StaticResource GuardianPrimitive.HorizontalLine}"
    Width="16"
    Canvas.Left="2"
    Canvas.Top="4"/>

                        <!-- Segment diagonal -->

                        <Rectangle
    Width="10"
    Height="2"
    RadiusX="1"
    RadiusY="1"
    Fill="{DynamicResource GuardianBrush.Accent}"
    Canvas.Left="18"
    Canvas.Top="6"
    RenderTransformOrigin="0.5,0.5">

                            <Rectangle.RenderTransform>
                                <RotateTransform Angle="-45"/>
                            </Rectangle.RenderTransform>

                        </Rectangle>

                        <!-- Segment horizontal secondaire -->

                        <Rectangle
                            
    Style="{StaticResource GuardianPrimitive.HorizontalLine}"
    Width="10"
    Canvas.Left="26"
    Canvas.Top="4"/>

                        <!-- Segment vertical -->

                        <Rectangle
    Style="{StaticResource GuardianPrimitive.VerticalLine}"
    Canvas.Left="2"
    Canvas.Top="2"/>
                        
                    </Canvas>
                    
                </ControlTemplate>
                
            </Setter.Value>
        </Setter>

    </Style>

</ResourceDictionary>