<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:ArkPilot.Controls">

    <Style TargetType="{x:Type controls:GuardianAccent}">

        <Setter Property="Width"
                Value="48"/>

        <Setter Property="Height"
                Value="12"/>

        <Setter Property="Template">

            <Setter.Value>

                <ControlTemplate TargetType="{x:Type controls:GuardianAccent}">

                    <Grid
    Width="48"
    Height="12"
    Background="Transparent">

                        <Canvas
        x:Name="LineAccent"
        Width="48"
        Height="12">

                            <Rectangle
    Style="{StaticResource GuardianPrimitive.HorizontalLine}"
    Width="18"
    Canvas.Left="0"
    Canvas.Top="5"/>
                            
                        </Canvas>

                        <Canvas
    x:Name="TripleAccent"
    Width="48"
    Height="12"
    Visibility="Collapsed">

                            <Rectangle
    Style="{StaticResource GuardianPrimitive.HorizontalLine}"
    Width="6"
    Canvas.Left="0"
    Canvas.Top="5"/>

                            <Rectangle
    Style="{StaticResource GuardianPrimitive.HorizontalLine}"
    Width="6"
    Canvas.Left="9"
    Canvas.Top="5"/>

                            <Rectangle
    Style="{StaticResource GuardianPrimitive.HorizontalLine}"
    Width="6"
    Canvas.Left="18"
    Canvas.Top="5"/>
                            
                        </Canvas>
                    </Grid>

                    <ControlTemplate.Triggers>

                        <Trigger Property="Type"
             Value="Line">

                            <Setter TargetName="LineAccent"
                Property="Visibility"
                Value="Visible"/>

                            <Setter TargetName="TripleAccent"
                Property="Visibility"
                Value="Collapsed"/>

                        </Trigger>

                        <Trigger Property="Type"
             Value="Triple">

                            <Setter TargetName="LineAccent"
                Property="Visibility"
                Value="Collapsed"/>

                            <Setter TargetName="TripleAccent"
                Property="Visibility"
                Value="Visible"/>

                        </Trigger>

                    </ControlTemplate.Triggers>

                </ControlTemplate>

            </Setter.Value>

        </Setter>

    </Style>

</ResourceDictionary>