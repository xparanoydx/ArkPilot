<Window x:Class="ArkPilot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ArkPilot"
        Width="1400"
        Height="800"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BrushBackground}">

    <Window.Resources>

        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Margin" Value="10,4"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource BrushCardHover}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0"
                Background="#181827"
                BorderBrush="{StaticResource BrushBorder}"
                BorderThickness="0,0,1,0">

            <DockPanel>

                <StackPanel DockPanel.Dock="Top">

                    <StackPanel Orientation="Horizontal"
            Margin="20,20,20,15">

                        <Image Width="52"
           Height="52"
           Source="/Assets/Images/ArkPilotLogo.png"/>

                        <StackPanel Margin="12,0,0,0"
                VerticalAlignment="Center">

                            <TextBlock Text="ArkPilot"
                   FontSize="28"
                   FontWeight="Bold"
                   Foreground="White"/>

                            <TextBlock Text="Control your ARK server."
                   FontSize="12"
                   Foreground="#B8B8C8"/>
                        </StackPanel>

                    </StackPanel>

                    <Separator Margin="12,0,12,12"
                               Background="{StaticResource BrushBorder}"/>

                    <Button Content="🏠 Dashboard"
Style="{StaticResource SidebarButtonStyle}"        Click="Dashboard_Click"/>

                    <Button Content="🖥 Serveur"
Style="{StaticResource SidebarButtonStyle}"        Click="Server_Click"/>

                    <Button x:Name="PlayersMenuButton"
                            Content="🛡 Administration joueurs  ▶"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="TogglePlayersMenu_Click"/>

                    <StackPanel x:Name="PlayersSubMenu"
                                Visibility="Collapsed"
                                Margin="20,0,0,0">

                        <Button Content="👤 Joueurs"
                                Style="{StaticResource SidebarButtonStyle}"
                                Click="Players_Click"/>

                        <Button Content="🚫 Joueurs bannis"
                                Style="{StaticResource SidebarButtonStyle}"
                                Click="BannedPlayers_Click"/>

                        <Button Content="🏰 Tribus"
                                Style="{StaticResource SidebarButtonStyle}"
                                Click="Tribes_Click"/>

                        <Button Content="🦖 Dinos"
                                Style="{StaticResource SidebarButtonStyle}"
                                Click="Dinos_Click"/>

                        <Button Content="📜 Historique admin"
                                Style="{StaticResource SidebarButtonStyle}"
                                Click="AdminHistory_Click"/>


                    </StackPanel>

                    <Button Content="📢 Messages"
                        Style="{StaticResource SidebarButtonStyle}"
                        Click="Chat_Click"/>

                    <Button Content="💾 Sauvegardes"
Style="{StaticResource SidebarButtonStyle}"        Click="Backups_Click"/>

                    <Button Content="🎉 Événements"
        Style="{StaticResource SidebarButtonStyle}"
        Click="Events_Click"/>

                    <Button Content="🖥 Console RCON"
Style="{StaticResource SidebarButtonStyle}"        Click="Console_Click"/>

                    <Button Content="⚙ Paramètres"
Style="{StaticResource SidebarButtonStyle}"        Click="Settings_Click"/>


                    <Button Content="📁 Explorateur FTP"
        Style="{StaticResource SidebarButtonStyle}"
        Click="FtpExplorer_Click"/>

                    <Button Content="ℹ À propos"
        Style="{StaticResource SidebarButtonStyle}"
        Click="About_Click"/>


                </StackPanel>

                <Border DockPanel.Dock="Bottom"
                        Background="{StaticResource BrushCard}"
                        BorderBrush="{StaticResource BrushBorder}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="12"
                        Margin="12">

                    <StackPanel>

                        <TextBlock Text="État serveur"
                                   Foreground="{StaticResource BrushTextSecondary}"
                                   FontSize="12"/>

                        <TextBlock Text="🟢 Connecté"
                                   Foreground="{StaticResource BrushTextPrimary}"
                                   FontWeight="Bold"
                                   Margin="0,6,0,0"/>

                        <TextBlock Text="ArkPilot"
                                   Foreground="{StaticResource BrushTextSecondary}"
                                   FontSize="11"
                                   Margin="0,8,0,0"/>

                    </StackPanel>

                </Border>

            </DockPanel>

        </Border>

        <!-- CONTENU -->
        <Grid Grid.Column="1">

            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition x:Name="LogRow"
                               Height="160"/>
            </Grid.RowDefinitions>
            
            <Border Background="{StaticResource BrushBackground}"
                    Padding="10">

                <Frame x:Name="MainContent"
                       NavigationUIVisibility="Hidden"/>

            </Border>

            <Border Grid.Row="1"
        Background="#151522"
        BorderBrush="{StaticResource BrushBorder}"
        BorderThickness="1"
        Padding="5">

                <DockPanel>

                    <Button x:Name="ToggleLogsButton"
                DockPanel.Dock="Top"
                Width="180"
                Height="38"
                HorizontalAlignment="Right"
                Margin="0,0,0,5"
                Content="⛶ Agrandir les logs"
                Click="ToggleLogs_Click"/>

                    <ListBox x:Name="LogList"
                 Foreground="White"
                 Background="#151522"
                 BorderThickness="0"/>

                </DockPanel>

            </Border>
            
        </Grid>

        <!-- STATUS BAR -->
        <StatusBar Grid.Row="1"
                   Grid.ColumnSpan="2"
                   Background="#181827"
                   Foreground="White">

            <StatusBarItem>
                <TextBlock x:Name="StatusRcon"
                           Text="🔴 RCON : Déconnecté"/>
            </StatusBarItem>

            <Separator/>

            <StatusBarItem>
                <TextBlock x:Name="StatusNitrado"
                           Text="🔴 Nitrado : Déconnecté"/>
            </StatusBarItem>

            <Separator/>

            <StatusBarItem>
                <TextBlock x:Name="StatusPlayers"
                           Text="👥 0 joueur"/>
            </StatusBarItem>

            <Separator/>

            <TextBlock x:Name="PingText"
                       Foreground="LightGreen"
                       Margin="10,0,0,0"/>

            <Separator/>

            <StatusBarItem>
                <TextBlock x:Name="StatusClock"
                           Text="🕒 --:--:--"/>
            </StatusBarItem>

        </StatusBar>

    </Grid>

</Window>